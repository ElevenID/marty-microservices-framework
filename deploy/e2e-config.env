# MMF E2E Test Configuration

# Cluster Configuration
CLUSTER_NAME_PREFIX="mmf"
DEFAULT_TIMEOUT=300
KUBECTL_TIMEOUT=60

# Image Configuration
IMAGE_REGISTRY="mmf"
IMAGE_NAME="identity-service"
DEFAULT_TAG="e2e-test"

# Kubernetes Configuration
DEFAULT_NAMESPACE="mmf-system"
SERVICE_NAME="identity-service"
REPLICAS=2

# Test Configuration
MAX_RETRIES=3
RETRY_DELAY=5

# Test Data
TEST_USERS='[
  {"username": "admin", "password": "admin123"},
  {"username": "user", "password": "password"},
  {"username": "demo", "password": "demo123"}
]'

# API Endpoints to Test
HEALTH_ENDPOINT="/health"
USERS_ENDPOINT="/users"
AUTH_ENDPOINT="/authenticate"
EVENTS_ENDPOINT="/events"

# Expected Response Patterns
HEALTH_SUCCESS_PATTERN='"status":"healthy"'
USERS_SUCCESS_PATTERN='"test_users"'
AUTH_SUCCESS_PATTERN='"success":true'
AUTH_FAILURE_PATTERN='"success":false'
EVENTS_SUCCESS_PATTERN='"events"'

# Load Testing Configuration (for future use)
LOAD_TEST_ENABLED=false
LOAD_TEST_CONCURRENT_USERS=10
LOAD_TEST_DURATION=30

# Security Testing Configuration (for future use)
SECURITY_TEST_ENABLED=false

# Performance Thresholds (for future use)
MAX_RESPONSE_TIME_MS=1000
MIN_AVAILABILITY_PERCENT=99
